<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_gupit_commission" model="ir.ui.view">
        <field name="name">sale.order.form.gupit.commission</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sales_person']/field[@name='user_id']" position="after">
                <field name="salesman_id" options="{'no_create': True}"/>
                <field name="regular_commission"/>
                <field name="over_the_counter_commission"/>
            </xpath>
        </field>
    </record>
</odoo>
