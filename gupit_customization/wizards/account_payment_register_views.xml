<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_register_form_inherit" model="ir.ui.view">
        <field name="name">account.payment.register.form.gupit</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <!-- Payment channel selector before journal -->
            <xpath expr="//field[@name='journal_id']" position="before">
                <field name="payment_channel"/>
            </xpath>
            <!-- Check fields after payment_date -->
            <xpath expr="//field[@name='payment_date']" position="after">
                <field name="check_date" invisible="payment_channel != 'pdc'" required="payment_channel == 'pdc'"/>
                <field name="check_reference" invisible="payment_channel != 'pdc'" required="payment_channel == 'pdc'"/>
                <field name="reference_cr_number" invisible="payment_channel != 'pdc'"/>
            </xpath>
            <!-- Comment after Memo -->
            <xpath expr="//field[@name='communication']" position="after">
                <field name="check_comment" invisible="payment_channel != 'pdc'"/>
            </xpath>
        </field>
    </record>
</odoo>
