<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_deposit_wizard_form" model="ir.ui.view">
        <field name="name">gupit.deposit.wizard.form</field>
        <field name="model">gupit.deposit.wizard</field>
        <field name="arch" type="xml">
            <form string="Deposit Check">
                <group>
                    <field name="payment_id" invisible="1"/>
                    <field name="payment_ids" invisible="1"/>
                    <field name="deposited_date"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
